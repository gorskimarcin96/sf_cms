<footer class="main-footer">
    <div class="bg-black footer">
        <div class="container py-1">
            <div class="row">
                <div class="col-sm-4">
                    <section>
                        <div class="font-weight-bolder mb-3">{{ 'Contact'|trans }}:</div>
                        <div><b>{{ 'Phone'|trans }}</b>: {{ phone }}</div>
                        <div><b>Email</b>: <a href="mailto:{{ email }}">{{ email }}</a></div>
                        <div><b>{{ 'Address'|trans }}</b>: {{ address }}</div>
                    </section>
                </div>
                <div class="col-sm-4">
                    <section>
                        <div class="font-weight-bolder">Menu:</div>
                        {% for route, name in frontendManager.menu %}
                            <a href="{{ route }}">{{ name }}</a> -
                        {% endfor %}
                        <a target="_blank" href="https://github.com/gorskimarcin96">github</a> -
                        <a target="_blank" href="{{ asset("upload/cv.pdf") }}">CV</a>
                    </section>
                </div>
                <div class="col-sm-4 icons d-flex justify-content-end">
                    <a class="icon" href="{{ url("homepage") }}">
                        <i class="fa fa-home"></i>
                    </a>
                    <a class="icon" target="_blank" href="https://github.com/gorskimarcin96">
                        <i class="fa fa-github"></i>
                    </a>
                    <a class="icon" target="_blank" href="{{ linkedin }}">
                        <i class="fa fa-linkedin-square"></i>
                    </a>
                    <a class="icon">
                        <i class="fa fa-chevron-up" id="scroll_up"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="container text-center site py-1">
            {{  'mgorski.dev'|upper }} - {{ "now"|date('Y') }}
        </div>
    </div>
</footer>