{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Dashboard{% endblock %}
{% block content_title %}Dashboard{% endblock %}

{% block main %}
    <div id="main">
        <div class="row">
            <div class="col-lg-12 col-xl-6">
                <div class="card m-2">
                    <div class="card-header fw-bold">Run processes php</div>
                    <div class="card-body p-0 table-responsive rounded">
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                            <tr>
                                <th>PID</th>
                                <th>TTY</th>
                                <th>STAT</th>
                                <th>TIME</th>
                                <th>COMMAND</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for process in processes %}
                                <tr>
                                    <td>{{ process.pid }}</td>
                                    <td>{{ process.tty }}</td>
                                    <td>{{ process.stat }}</td>
                                    <td>{{ process.time }}</td>
                                    <td>{{ process.command }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5">
                                        <div class="alert alert-danger rounded">Not found.</div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-12 col-xl-6">
                <div class="card m-2">
                    <div class="card-header fw-bold">OVH services</div>
                    <div class="card-body p-0 table-responsive rounded">
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                            <tr>
                                <th>ID</th>
                                <th>Service</th>
                                <th>Created at</th>
                                <th>Expiration date / Next billing date</th>
                                <th>Days to paid</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for service in services %}
                                <tr class="{% if service.daysToPaid <= 7 %}table-danger{% elseif service.daysToPaid <= 30 %}table-warning{% endif %}">
                                    <td>{{ service.id }}</td>
                                    <td>
                                        <a href="http://{{ service.displayName }}" target="_blank">
                                            {{ service.displayName }}
                                        </a>
                                    </td>
                                    <td>{{ service.createdAt|date("d-m-Y") }}</td>
                                    <td>
                                        {{ service.expiredDate|date("d-m-Y") }} /
                                        {{ service.nexBillingDate|date("d-m-Y") }}
                                    </td>
                                    <td>{{ service.daysToPaid }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5">
                                        <div class="alert alert-danger rounded">Not found.</div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-12 col-xl-3">
                <div class="card m-2">
                    <div class="card-header fw-bold">Stats</div>
                    <div class="card-body p-0 table-responsive rounded">
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                            <tr>
                                <th>Last days</th>
                                <th>Entry number</th>
                                <th>Refresh number</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for data in statics_data %}
                                <tr>
                                    <td>{{ data.days }}</td>
                                    <td>{{ data.entries }}</td>
                                    <td>{{ data.refresh }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3">
                                        <div class="alert alert-danger rounded">Not found.</div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-12 col-xl-9">
                <div class="card m-2">
                    <div class="card-header fw-bold">Chart</div>
                    <div class="card-body">{{ render_chart(chart) }}</div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}