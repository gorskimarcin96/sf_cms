{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Dashboard{% endblock %}

{% block main %}
    <div id="main">
        <div class="row">
            <div class="col-lg-12 col-xl-6">
                <div>
                    <div class="card m-2">
                        <div class="card-header">Statystyki</div>
                        <div class="card-body">
                            <table class="table table-striped table-light">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Ostatnie dni</th>
                                        <th>Liczba wejść</th>
                                        <th>Liczba odświeżeń</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for data in statics_data %}
                                    <tr>
                                        <td>{{ data.days }}</td>
                                        <td>{{ data.entries }}</td>
                                        <td>{{ data.refresh }}</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <input type="hidden" value="{{ chart_data }}" id="counter_chart_data">
{% endblock %}