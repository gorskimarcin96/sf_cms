{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Dashboard{% endblock %}

{% block main %}
    <div id="main">
        <div class="row">
            <div class="col-lg-12 col-xl-6">
                <div class="card m-2">
                    <div class="card-header">Processes</div>
                    <div class="card-body">
                        <table class="table table-striped table-light">
                            <thead class="table-dark">
                            <tr>
                                <th>PID</th>
                                <th>TTY</th>
                                <th>STAT</th>
                                <th>TIME</th>
                                <th>COMMAND</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for process in processes %}
                                <tr class="{{ 'php' in process.command ? 'table-info'}}">
                                    <td>{{ process.pid }}</td>
                                    <td>{{ process.tty }}</td>
                                    <td>{{ process.stat }}</td>
                                    <td>{{ process.time }}</td>
                                    <td>{{ process.command }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5">
                                        <div class="alert alert-danger rounded">Not found.</div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-12 col-xl-6">
                <div class="card m-2">
                    <div class="card-header">Statystyki</div>
                    <div class="card-body">
                        <table class="table table-striped table-light">
                            <thead class="table-dark">
                            <tr>
                                <th>Ostatnie dni</th>
                                <th>Liczba wejść</th>
                                <th>Liczba odświeżeń</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for data in statics_data %}
                                <tr>
                                    <td>{{ data.days }}</td>
                                    <td>{{ data.entries }}</td>
                                    <td>{{ data.refresh }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3">
                                        <div class="alert alert-danger rounded">Not found.</div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            {% for chart in charts %}
                <div class="{{ loop.first ? 'col-lg-12 col-xl-6' : 'col-12' }}">
                    <div class="card m-2">
                        <div class="card-header">Wykres</div>
                        <div class="card-body">{{ render_chart(chart) }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}